{
  "name": "holdemmaster",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "check:intl-links": "node scripts/check-intl-links.mjs",
    "check:stale": "node scripts/check-translation-staleness.mjs",
    "prebuild": "npm run check:intl-links && npm run generate:sitemap",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gsc": "node scripts/gsc-fetch.mjs",
    "gsc:both": "node scripts/gsc-fetch.mjs --both",
    "gsc:analyze": "node scripts/gsc-analyze.mjs",
    "gsc:lang": "node scripts/gsc-lang.mjs",
    "gsc:inspect": "node scripts/gsc-inspect.mjs",
    "ga": "node scripts/ga-fetch.mjs",
    "compress:images": "node scripts/compress-images.mjs --apply",
    "compress:images:preview": "node scripts/compress-images.mjs",
    "generate:beginner-pdf": "node scripts/generate-beginner-pdf.mjs"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.4",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.4.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "critters": "^0.0.23",
    "googleapis": "^173.0.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
